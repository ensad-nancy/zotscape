# Copy this file to .env.local and fill only the keys you want to use.
# .env.local is ignored by Git.

# Open Library does not require an API key.

# Optional: improves Google Books cover lookup.
GOOGLE_BOOKS_API_KEY=

# Optional: paid/commercial fallback for book metadata and covers.
ISBNDB_API_KEY=

# Optional collector settings.
ZOTSCAPE_ZOTERO_GROUP_ID=
ZOTSCAPE_ROOT_COLLECTION=
ZOTSCAPE_SCREENSHOT_LIMIT=
ZOTSCAPE_SCREENSHOT_ATTEMPT_LIMIT=
ZOTSCAPE_SCREENSHOT_CONCURRENCY=
ZOTSCAPE_ENRICH_CONCURRENCY=
ZOTSCAPE_ZOTERO_PAGE_CONCURRENCY=
ZOTSCAPE_WEB_CACHE_TTL_HOURS=
ZOTSCAPE_WEB_CACHE_HTML_CHARS=
ZOTSCAPE_VALIDATE_CACHE_ASSETS=
